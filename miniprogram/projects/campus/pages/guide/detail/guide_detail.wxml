<view wx:if="{{isLoad===null}}" class="margin-top load notexist text-l load-project"></view>
<view wx:if="{{isLoad===false}}" class="margin-top load loading text-l load-project"></view>

<block wx:if="{{isLoad}}">
	<view class="main padding-project">
	<view class="article-box margin-top-xs">
		<!-- article content begin -->
		<view class="article card-project shadow-project">
			<view class="title"><text user-select="true">{{guide.GUIDE_TITLE}}</text></view>
				<view class="time"> {{guide.GUIDE_ADD_TIME}} {{guide.GUIDE_CATE_NAME}} </view> 


			<block wx:for="{{guide.GUIDE_CONTENT}}" wx:key="key">
				<view class="content" wx:if="{{item.type=='text'}}">
					<text user-select="{{true}}">{{item.val}}</text>
				</view>

				<view class="pics" wx:if="{{item.type=='img'}}">
					<image bindtap="url" data-type='img' data-url="{{item.val}}" show-menu-by-longpress="{{true}}" class="loading" mode='widthFix' lazy-load="true" src="{{item.val}}">
					</image>
				</view>
			</block>
			<!-- article content end -->

		</view>
		<!-- article content end -->

		</view>

	</view>

	<cmpt-detail mode="mode1" doFav="{{false}}" topBtnShow="{{topBtnShow}}" oid="{{guide._id}}" cate="{{guide.GUIDE_CATE_NAME}}" title="{{guide.GUIDE_TITLE}}" cover="{{guide.GUIDE_PIC[0]||'/images/cover.gif'}}" qr="{{guide.GUIDE_QR}}" desc="查看详情"  bg="{{skin.PROJECT_COLOR}}"></cmpt-detail>
</block>