@import "../../../style/skin.wxss";

.container {
  padding: 24rpx 24rpx 0;
}

.article,
.comment-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.user-meta {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

.time-row {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.chat-btn {
  margin-left: auto;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #6b7cff 0%, #5368ff 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 30rpx;
}

.main-content {
  margin-top: 24rpx;
}

.board-line {
  color: #333;
  line-height: 1.8;
}

.board-to {
  font-size: 36rpx;
  font-weight: 700;
}

.board-desc {
  margin-top: 16rpx;
  font-size: 30rpx;
  white-space: pre-wrap;
}

.board-from {
  margin-top: 20rpx;
  text-align: right;
  color: #999;
  font-size: 24rpx;
}

.pic-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.pic {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.comment-entry {
  color: #5b6cff;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
}

.comment-empty {
  color: #999;
  font-size: 26rpx;
  text-align: center;
  padding: 36rpx 0;
}

.comment-item {
  display: flex;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.comment-item:first-child {
  border-top: none;
  padding-top: 0;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f5;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.comment-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-wrap;
}

.comment-image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.comment-image {
  width: 176rpx;
  height: 176rpx;
  border-radius: 14rpx;
  background: #f5f5f5;
}

.comment-oprt {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.comment-like,
.comment-del {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #888;
  font-size: 24rpx;
}

.comment-del {
  color: #e65a5a;
}

.inline-comment-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.comment-toolbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  width: 100%;
}

.comment-image-picker {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #f3f4f8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b86ff;
  flex-shrink: 0;
}

.inline-comment-input {
  flex: 1;
  height: 92rpx;
  background: #f3f4f8;
  border-radius: 46rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  min-width: 0;
  box-sizing: border-box;
}

.inline-comment-send {
  min-width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 38rpx;
  background: linear-gradient(135deg, #6b7cff 0%, #5368ff 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0 18rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(91, 108, 255, 0.22);
}

.inline-comment-send.disabled {
  background: #cfd6ff;
  box-shadow: none;
}

.comment-image-scroll {
  width: 100%;
  white-space: nowrap;
}

.comment-image-preview-list {
  display: inline-flex;
  gap: 12rpx;
}

.comment-image-preview-item {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
}

.comment-image-preview {
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
}

.comment-image-remove {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
}
