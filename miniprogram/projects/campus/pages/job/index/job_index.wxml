<view wx:if="{{!isLoad}}" class="margin-top load loading text-l load-project"></view>
<block wx:if="{{isLoad}}">
	<cmpt-comm-list id="job-list" type="job-list" search="{{search||''}}" _params="{{_params}}" _menus="{{sortMenus}}" _items="{{sortItems}}" route="job/list" isTotalMenu="{{true}}" pulldownType="{{['modal','modal','modal']}}" sortMenusDefaultIndex="{{sortMenusDefaultIndex}}" topBottom="120" placeholder="搜索" bind:list="bindCommListCmpt">

		<view slot="searchEnd">
			<button bindtap="bindMyTap" class="btn round bg-project text-white margin-right-s"><text class="icon-moreandroid margin-right-xxs"></text>我的</button>
		</view>

		<!-- List Begin -->
		<view class="list">
			<block wx:for="{{dataList.list}}" wx:key="k">
				<view class="item shadow-project" bindtap="bindDetailTap" data-id="{{item._id}}">
					<view class="left">
						<view class="line1">
							<view class="title content-cut-two">
								<text>{{item.JOB_OBJ.title}}  <text wx:if="{{item.JOB_ORDER==0}}" class="tag small radius bg-blue light">置顶</text></text>
							</view>
						</view>
						<view class="line-bottom">
							<view class="line2 margin-top-xxs">
								<text><text class="icon-attention margin-right-xxxs"></text>{{item.JOB_VIEW_CNT}}</text>
								<text><text class="icon-appreciate{{item.like?'fill':''}} margin-right-xxxs"></text>{{item.JOB_LIKE_CNT}}</text>
								<text catchtap="bindDetailTap" data-id="{{item._id}}" data-focus-comment="1"><text class="icon-comment margin-right-xxxs"></text>{{item.JOB_COMMENT_CNT}}</text>
								<text><text class="icon-favor{{item.fav?'fill':''}}" style="{{item.fav?'color:#5b6cff':''}} margin-right-xxxs"></text>{{item.JOB_FAV_CNT}}</text>
							</view>
							<view class="line2">
								<text>{{item.JOB_ADD_TIME}}</text>
								<text>#{{item.JOB_CATE_NAME}}</text>
							</view>
						</view>
					</view>
					<view class="right">
						<view wx:if="{{item.JOB_STATUS==1}}" class="status bg-green light">进行中</view>
						<view wx:elif="{{item.JOB_STATUS==0}}" class="status bg-grey light">已结束</view>
						<image wx:if="{{item.JOB_OBJ.pic && item.JOB_OBJ.pic[0]}}" mode="aspectFill" lazy-load="{{true}}" class="loading" src="{{item.JOB_OBJ.pic[0]}}">
						</image>
						<view wx:else class="loading" style="display:flex;align-items:center;justify-content:center;background:#f5f6fa;color:#c0c4cc;font-size:24rpx;">暂无图片</view>
					</view>

					<view wx:if="{{nowUserId==item.JOB_USER_ID}}" class="mark-mine bg-brown light">我的</view>


				</view>
				<view class="oprt" wx:if="{{nowUserId==item.JOB_USER_ID||isAdmin}}">
					<!--<view bindtap="url" data-url="../detail/job_detail?id={{item._id}}"><text class="icon-attention"></text>详情</view>-->

					<view class="bg-pink light" bindtap="bindStatusTap" data-id="{{item._id}}"><text class="icon-settings"></text>状态设定</view>

					<view class="bg-blue light" bindtap="url" data-url="../edit/job_edit?id={{item._id}}"><text class="icon-edit"></text>编辑</view>

					<view class="bg-orange light" bindtap="bindDelTap" data-id="{{item._id}}"><text class="icon-delete"></text>删除</view>
				</view>
			</block>
		</view>

		<!-- List END -->

		<!--load begin-->
		<import src="../../../../../tpls/public/list_load_tpl.wxml" />
		<template is="listLoadTpl" data="{{skin:'load-project',dataList}}" />
		<!--load end-->



	</cmpt-comm-list>

	<!--  button Begin -->
	<!--  button END -->

	<view wx:if="{{!isAdmin}}" class="post safe-bottom">
		<view capture-bind:tap="bindPostTap" class="inner shadow-project"><text class="icon-cartfill margin-right-xs"></text>发 布</view>
	</view>
</block>
