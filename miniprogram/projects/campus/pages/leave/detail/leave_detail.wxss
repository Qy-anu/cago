/* projects/campus/pages/leave/detail/leave_detail.wxss */
.container {
  padding: 24rpx 24rpx 0;
}

.header,
.content,
.stats,
.comment-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.time {
  margin-top: 8rpx;
  color: #999;
  font-size: 24rpx;
}

.chat-btn {
  margin-left: auto;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #6b7cff 0%, #5368ff 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 30rpx;
}

.status-badge {
  margin-bottom: 16rpx;
}

.badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}

.price {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff4d4f;
  margin-bottom: 16rpx;
}

.text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
}

.pic-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.pic {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #666;
  font-size: 26rpx;
}

.comment-entry {
  color: #5b6cff;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
}

.comment-empty {
  color: #999;
  font-size: 26rpx;
  text-align: center;
  padding: 36rpx 0;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.comment-item:first-child {
  border-top: none;
  padding-top: 0;
}

.comment-left {
  margin-right: 20rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f5;
}

.comment-right {
  flex: 1;
}

.comment-line1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.comment-user {
  color: #333;
  font-size: 28rpx;
  font-weight: 600;
}

.comment-time {
  color: #999;
  font-size: 22rpx;
}

.comment-content {
  margin-top: 12rpx;
  color: #333;
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.comment-image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.comment-image {
  width: 176rpx;
  height: 176rpx;
  border-radius: 14rpx;
  background: #f5f5f5;
}

.comment-oprt {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.comment-like,
.comment-del {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #888;
  font-size: 24rpx;
}

.comment-del {
  color: #e65a5a;
}

.inline-comment-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.comment-toolbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  width: 100%;
}

.comment-toolbar-left {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 50%;
  min-width: 0;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.comment-toolbar-left-new {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  padding: 0 8rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.comment-toolbar-btn {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #f3f4f8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b86ff;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.inline-comment-input {
  flex: 1;
  height: 92rpx;
  background: #f3f4f8;
  border-radius: 46rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  min-width: 0;
  box-sizing: border-box;
}

.inline-comment-send {
  width: 10%;
  min-width: 80rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 38rpx;
  background: linear-gradient(135deg, #6b7cff 0%, #5368ff 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(91, 108, 255, 0.22);
}

.inline-comment-send.disabled {
  background: #cfd6ff;
  box-shadow: none;
}

.comment-image-scroll {
  width: 100%;
  white-space: nowrap;
}

.comment-image-preview-list {
  display: inline-flex;
  gap: 12rpx;
}

.comment-image-preview-item {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
}

.comment-image-preview {
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
}

.comment-image-remove {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
}