<view wx:if="{{!isLoad}}" class="margin-top load loading text-l load-project"></view>
<block wx:if="{{isLoad}}">
	<cmpt-comm-list id="emotion-list" type="emotion-list" search="{{search||''}}" _params="{{_params}}" _menus="{{sortMenus}}" _items="{{sortItems}}" route="emotion/list" isTotalMenu="{{true}}" pulldownType="{{['modal','modal','modal']}}" sortMenusDefaultIndex="{{sortMenusDefaultIndex}}" topBottom="120" placeholder="搜索心情" bind:list="bindCommListCmpt">
		<view slot="searchEnd">
			<button bindtap="bindMyTap" class="btn round bg-project text-white margin-right-s"><text class="icon-moreandroid margin-right-xxs"></text>我的</button>
		</view>

		<view class="list">
			<block wx:for="{{dataList.list}}" wx:key="k">
				<view class="item shadow-project" bindtap="bindDetailTap" data-id="{{item._id}}">
					<view wx:if="{{nowUserId==item.EMOTION_USER_ID}}" class="mark-mine bg-white">我的</view>

					<view wx:if="{{nowUserId==item.EMOTION_USER_ID&&item.EMOTION_STATUS==0}}" class="mark-status bg-red">仅自己可见</view>

					<view class="top">
						<image class="left loading" mode="aspectFill" lazy-load="{{true}}" src="{{item.user.USER_PIC||'../../../images/default-avatar.png'}}"></image>
						<view class="right">
							<view class="title">
								<text class="name text-white text-bold">{{item.EMOTION_ANONYMOUS ? '匿名用户' : item.user.USER_NAME}} <text wx:if="{{item.EMOTION_ANONYMOUS}}" class="tag small radius bg-gray light">匿名</text> <text wx:if="{{item.EMOTION_ORDER==0}}" class="tag small radius bg-pink light">置顶</text></text>
								<text class="date"></text>
							</view>
							<view class="desc"><text>{{item.EMOTION_OBJ.content}}</text></view>

							<view class="pic" wx:if="{{item.EMOTION_OBJ.pic}}">
								<image wx:for="{{item.EMOTION_OBJ.pic}}" wx:key="key1" wx:for-item="itm" bindtap="url" data-type="img" data-url="{{itm}}" class="loading img{{item.EMOTION_OBJ.pic.length}}" mode="aspectFill" lazy-load="{{true}}" src="{{itm}}"></image>
							</view>

							<view class="line2">{{item.EMOTION_ADD_TIME}}</view>

							<view class="data">
								<view><text class="icon-attention"></text>{{item.EMOTION_VIEW_CNT}}</view>
								<view catchtap="bindLikeTap" data-idx="{{index}}" data-id="{{item._id}}"><text class="icon-appreciate{{item.like?'fill text-red':''}}"></text>{{item.EMOTION_LIKE_CNT}}</view>
								<view catchtap="bindDetailTap" data-id="{{item._id}}" data-focus-comment="1"><text class="icon-comment"></text>{{item.EMOTION_COMMENT_CNT}}</view>
								<view catchtap="bindFavTap" data-idx="{{index}}" data-id="{{item._id}}"><text class="icon-favor{{item.fav?'fill':''}}" style="{{item.fav?'color:#5b6cff':''}}"></text>{{item.EMOTION_FAV_CNT}}</view>
							</view>
						</view>
					</view>
					<view class="bottom">
						<view class="info">
							<view><text class="icon-attention"></text>{{item.EMOTION_VIEW_CNT}}</view>
							<view catchtap="bindLikeTap" data-idx="{{index}}" data-id="{{item._id}}"><text class="icon-appreciate{{item.like?'fill text-white':''}}"></text>{{item.EMOTION_LIKE_CNT}}</view>
							<view catchtap="bindDetailTap" data-id="{{item._id}}" data-focus-comment="1"><text class="icon-comment"></text>{{item.EMOTION_COMMENT_CNT}}</view>
							<view catchtap="bindFavTap" data-idx="{{index}}" data-id="{{item._id}}"><text class="icon-favor{{item.fav?'fill':''}}" style="{{item.fav?'color:#5b6cff':''}}"></text>{{item.EMOTION_FAV_CNT}}</view>
						</view>
					</view>
				</view>
				<view class="oprt" wx:if="{{nowUserId==item.EMOTION_USER_ID||isAdmin}}">
					<view class="bg-pink light" bindtap="bindStatusTap" data-id="{{item._id}}"><text class="icon-settings"></text>状态设定</view>
					<view class="bg-blue light" bindtap="url" data-url="../edit/emotion_edit?id={{item._id}}"><text class="icon-edit"></text>编辑</view>
					<view class="bg-orange light" bindtap="bindDelTap" data-id="{{item._id}}"><text class="icon-delete"></text>删除</view>
				</view>
			</block>
		</view>

		<import src="../../../../../tpls/public/list_load_tpl.wxml" />
		<template is="listLoadTpl" data="{{skin:'load-project',dataList}}" />
	</cmpt-comm-list>

	<view wx:if="{{!isAdmin}}" class="post safe-bottom">
		<view capture-bind:tap="bindPostTap" class="inner shadow-project bg-pink"><text class="icon-edit margin-right-xs"></text>写心情</view>
	</view>
</block>
