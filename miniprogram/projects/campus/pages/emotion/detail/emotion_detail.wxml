<view wx:if="{{!isLoad}}" class="margin-top load loading text-l text-grey"></view>
<block wx:if="{{isLoad}}">

	<view class="container">
		<view class="header">
			<view class="user-info">
				<image class="avatar" src="{{emotion.EMOTION_ANONYMOUS ? '../../../images/default-avatar.png' : (emotion.user.USER_PIC||'../../../images/default-avatar.png')}}" style="filter: {{emotion.EMOTION_ANONYMOUS ? 'blur(5px)' : 'none'}};"></image>
				<view class="user-details">
					<text class="username">{{emotion.EMOTION_ANONYMOUS ? '匿名用户' : emotion.user.USER_NAME}} <text wx:if="{{emotion.EMOTION_ANONYMOUS}}" class="tag small radius bg-gray light">匿名</text></text>
					<text class="time">{{emotion.EMOTION_ADD_TIME}}</text>
				</view>
				<view wx:if="{{isLogin && !emotion.EMOTION_ANONYMOUS && emotion.EMOTION_USER_ID != nowUserId}}" class="chat-btn" bindtap="bindChatTap" data-user-id="{{emotion.EMOTION_USER_ID}}" data-user-name="{{emotion.user.USER_NAME}}" data-source-type="board" data-source-id="{{emotion._id}}" data-source-title="{{emotion.EMOTION_OBJ.title || '心情详情'}}">私聊</view>
			</view>
		</view>

		<view class="content">
			<view class="title" wx:if="{{emotion.EMOTION_OBJ.title}}">{{emotion.EMOTION_OBJ.title}}</view>
			<view class="text">{{emotion.EMOTION_OBJ.content}}</view>
			
			<view class="pic-list" wx:if="{{emotion.EMOTION_OBJ.pic && emotion.EMOTION_OBJ.pic.length}}">
				<image wx:for="{{emotion.EMOTION_OBJ.pic}}" wx:key="key" bindtap="url" data-type="img" data-url="{{item}}" class="pic" src="{{item}}"></image>
			</view>
		</view>

		<view class="stats">
			<view class="stat-item">
				<text class="icon-attention"></text>
				<text>{{emotion.EMOTION_VIEW_CNT}}</text>
			</view>
			<view class="stat-item">
				<text class="icon-appreciate"></text>
				<text>{{emotion.EMOTION_LIKE_CNT}}</text>
			</view>
			<view class="stat-item comment-entry" bindtap="bindCommentFocus">
				<text class="icon-comment"></text>
				<text>{{emotion.EMOTION_COMMENT_CNT}}</text>
			</view>
		</view>

		<view class="comment-section" id="comment-section">
			<view class="comment-title">全部评论（{{emotion.EMOTION_COMMENT_CNT||0}}）</view>
			<view wx:if="{{!commentList.length}}" class="comment-empty">暂无评论，快来抢沙发~</view>
			<view class="comment-list" wx:else>
				<view class="comment-item" wx:for="{{commentList}}" wx:key="_id">
					<view class="comment-left">
						<image class="comment-avatar" mode="aspectFill" src="{{item.user.USER_PIC||'../../../images/default-avatar.png'}}"></image>
					</view>
					<view class="comment-right">
						<view class="comment-line1">
							<text class="comment-user">{{item.user.USER_NAME}}</text>
							<text class="comment-time">{{item.COMMENT_ADD_TIME}}</text>
						</view>
						<view wx:if="{{item.COMMENT_OBJ.content}}" class="comment-content">{{item.COMMENT_OBJ.content}}</view>
						<view class="comment-image-list" wx:if="{{item.COMMENT_OBJ.img && item.COMMENT_OBJ.img.length}}">
							<image wx:for="{{item.COMMENT_OBJ.img}}" wx:key="key" wx:for-item="img" bindtap="url" data-type="img" data-url="{{img}}" class="comment-image" src="{{img}}" mode="aspectFill"></image>
						</view>
						<view class="comment-oprt">
							<view class="comment-like" bindtap="bindCommentLikeTap" data-id="{{item._id}}" data-idx="{{index}}">
								<text class="icon-appreciate{{item.like?'fill':''}}"></text>
								<text>{{item.COMMENT_LIKE_CNT}}</text>
							</view>
							<view wx:if="{{isLogin && item.COMMENT_USER_ID == nowUserId}}" bindtap="bindCommentDelTap" data-id="{{item._id}}" class="comment-del">删除</view>
						</view>
					</view>
				</view>
			</view>
		</view>

	</view>

	<cmpt-detail mode="mode1" topBtnShow="{{topBtnShow}}" oid="{{emotion._id}}" type="emotion" cate="{{emotion.EMOTION_CATE_NAME}}" title="{{emotion.EMOTION_OBJ.title || '心情详情'}}" cover="{{emotion.EMOTION_OBJ.pic[0]}}" desc="查看详情" doHome="{{false}}" doFav="{{false}}" doShare="{{false}}" iconOnly="{{true}}">
		<view class="inline-comment-wrap">
			<view class="comment-toolbar">
				<view class="comment-toolbar-left-new">
					<view class="comment-toolbar-btn" bindtap="bindFavTap">
						<text class="icon-favor{{emotion.fav?'fill':''}}" style="{{emotion.fav?'color:#5b6cff':''}}"></text>
					</view>
					<view class="comment-toolbar-btn" bindtap="bindShareTap">
						<text class="icon-forward"></text>
					</view>
					<view class="comment-toolbar-btn" bindtap="bindChooseCommentImage">
						<text class="icon-pic"></text>
					</view>
				</view>
				<input class="inline-comment-input" placeholder="发言要友善" value="{{commentContent}}" bindinput="bindCommentInput" bindfocus="bindCommentFocus" focus="{{commentFocus}}" confirm-type="send" bindconfirm="bindCommentSubmit" />
				<view class="inline-comment-send {{(!commentContent && !commentImages.length)||isCommentSubmitting?'disabled':''}}" bindtap="bindCommentSubmit">发送</view>
			</view>
			<scroll-view wx:if="{{commentImages.length}}" class="comment-image-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
				<view class="comment-image-preview-list">
					<view class="comment-image-preview-item" wx:for="{{commentImages}}" wx:key="key">
						<image class="comment-image-preview" src="{{item}}" mode="aspectFill"></image>
						<view class="comment-image-remove" bindtap="bindRemoveCommentImage" data-idx="{{index}}">×</view>
					</view>
				</view>
			</scroll-view>
		</view>
	</cmpt-detail>

</block>
